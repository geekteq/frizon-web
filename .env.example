APP_NAME=Frizon
APP_URL=http://localhost
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=frizon
DB_USER=root
DB_PASS=

UPLOAD_MAX_SIZE=10485760
NEARBY_RADIUS_METERS=100

# Phase 2: Routing — https://openrouteservice.org/dev/#/signup (free, 2000 req/day)
ORS_API_KEY=

# Phase 4: AI text generation — https://console.anthropic.com
# AI_PROVIDER=fake   (default, no API calls — use 'claude' in production)
AI_PROVIDER=fake
ANTHROPIC_API_KEY=

# Google Analytics — https://analytics.google.com
# Leave empty to disable tracking
GA_MEASUREMENT_ID=

# Amazon Associates affiliate tag — used to build affiliate links
AMAZON_ASSOCIATE_ID=

# Instagram publishing — https://developers.facebook.com/docs/instagram-platform/
# App ID: 2431950217255592  (see Meta Developer Console)
# App Secret: from Meta Developer Console → Your App → App settings → Basic
# User ID: GET https://graph.facebook.com/v21.0/me?fields=id,name&access_token=TOKEN
# Long-lived token: exchange short-lived token via oauth/access_token endpoint (see InstagramService.php)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
